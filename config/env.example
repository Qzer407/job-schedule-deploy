# 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/task_scheduler?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# Redis配置
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# RabbitMQ配置
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672

# XXL-JOB配置
XXL_JOB_ADMIN_ADDRESSES=http://xxl-job-admin:8080/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=default_token
